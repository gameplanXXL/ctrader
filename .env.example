# ctrader — environment variables template
#
# Copy to .env and fill in real values. .env is in .gitignore and MUST
# NEVER be committed. Chef's real PostgreSQL instance credentials,
# IB Flex token, and cTrader OAuth secrets all live here.

# --- Server ------------------------------------------------------------
# NFR-S2: bind to 127.0.0.1 only. Never set HOST=0.0.0.0.
HOST=127.0.0.1
PORT=8000

# --- PostgreSQL --------------------------------------------------------
# For Docker Compose dev stack this points at the `postgres` service.
# For Chef's existing PostgreSQL instance, set this to the real DSN.
DATABASE_URL=postgresql://ctrader:ctrader@postgres:5432/ctrader
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# --- Logging -----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=data/logs/ctrader.log
LOG_FILE_MAX_BYTES=104857600
LOG_FILE_BACKUP_COUNT=5

# --- Environment -------------------------------------------------------
ENVIRONMENT=development

# --- PostgreSQL service (used only by docker-compose.yml) --------------
# These are consumed by the `postgres` service at first-boot to create
# the database + user. They are NOT read by the ctrader application —
# the app only cares about DATABASE_URL above.
POSTGRES_DB=ctrader
POSTGRES_USER=ctrader
POSTGRES_PASSWORD=ctrader

# --- MCP fundamental (Story 1.6) ---------------------------------------
# MCP_FUNDAMENTAL_URL=http://127.0.0.1:8700

# --- Interactive Brokers (Epic 2) --------------------------------------
# IB_FLEX_TOKEN and IB_FLEX_QUERY_ID are required for the nightly
# auto-import job (Story 2.5, runs daily 07:00 UTC) and for the
# `python -m app.cli.ib_flex_import --pull` backfill command. When both
# are unset the scheduler logs `ib_flex_nightly.disabled_unconfigured`
# and the Health-Widget shows the job as `never_run` — safe default.
#
# Recommended IB Flex Query configuration (in IB Account Management
# → Reporting → Flex Queries → Activity Flex Query):
#   - Sections: Trades (Stocks + Options, Single-Leg only)
#   - Period:   Last 90 Days  ← sliding window; gives the nightly job
#               up to 90 days of backfill headroom on any single run
#   - Format:   XML
# For the initial 12-month backfill, temporarily set Period to
# "Last 365 Days", run `--pull` once, then reset to "Last 90 Days".
# IB_FLEX_TOKEN=
# IB_FLEX_QUERY_ID=
# IB_GATEWAY_HOST=127.0.0.1
# IB_GATEWAY_PORT=7497

# --- cTrader (Epic 8) --------------------------------------------------
# CTRADER_CLIENT_ID=
# CTRADER_CLIENT_SECRET=
# CTRADER_ACCOUNT_ID=
